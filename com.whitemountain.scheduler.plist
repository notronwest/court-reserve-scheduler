<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.whitemountain.scheduler</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/notronwest/data/court_reserve_scheduling/run_scheduler.sh</string>
    </array>

    <!-- Run daily at 8:00 AM -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/notronwest/Library/Logs/court_reserve/launchd_scheduler.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/notronwest/Library/Logs/court_reserve/launchd_scheduler_err.log</string>

    <!-- Run missed jobs when machine wakes up -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
