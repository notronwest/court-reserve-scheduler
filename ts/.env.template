# courtreserve-scheduler (TS) env — copy to .env and fill in. NEVER commit .env.

# The courtreserve-api HTTP service (runs on the club Mac mini).
CRAPI_URL=http://localhost:8787
CRAPI_KEY=

# LLM ranker (Pass 1+2) + !book/!move parser (Phase 3).
ANTHROPIC_API_KEY=
# Optional model overrides (default to the Python's models for shadow-run parity):
# CR_RANKER_MODEL=claude-sonnet-4-6
# CR_PARSER_MODEL=claude-haiku-4-5

# Discord listener (Phase 4). Bot token + webhook come from the same Discord
# app as the Python listener. Point CHANNEL_ID at the TEST channel until the TS
# listener is verified, then switch to the live channel.
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
# Test channel for shadow-running the TS listener before cutover:
DISCORD_CHANNEL_ID=1511935694107312179

# Where the listener reads/writes state (pending_approval.json, listener_state.json,
# pending_waitlist.json). Defaults to ../logs (the Python listener's dir) so the two
# can shadow-run against the same run.py output. Override to isolate during testing.
# CR_LOGS_DIR=

# Command the `!schedule` handler spawns to generate recommendations for a date
# (the date is appended as the last arg). Defaults to the TS scheduler CLI
# (`npx tsx src/cli.ts schedule <date>`); override only if needed.
# CR_SCHEDULE_CMD=npx tsx src/cli.ts schedule
