<?xml version="1.0" encoding="UTF-8"?>
<!-- LaunchAgent — runs check_waitlists.py at 9am, 11am, 1pm, 3pm, 5pm every day.
     Scans upcoming events for waitlists and posts Discord expansion proposals.

     Install:
       cp com.whitemountain.check-waitlists.plist ~/Library/LaunchAgents/
       launchctl load ~/Library/LaunchAgents/com.whitemountain.check-waitlists.plist

     Run manually now:
       launchctl start com.whitemountain.check-waitlists

     Uninstall:
       launchctl unload ~/Library/LaunchAgents/com.whitemountain.check-waitlists.plist
       rm ~/Library/LaunchAgents/com.whitemountain.check-waitlists.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.whitemountain.check-waitlists</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/notronwest/data/court_reserve_scheduling/venv/bin/python</string>
    <string>/Users/notronwest/data/court_reserve_scheduling/check_waitlists.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/notronwest/data/court_reserve_scheduling</string>

  <!-- Fire at 9am, 11am, 1pm, 3pm, 5pm every day -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>9</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>11</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>13</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>15</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>17</integer><key>Minute</key><integer>0</integer></dict>
  </array>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/notronwest/data/court_reserve_scheduling/logs/check_waitlists.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/notronwest/data/court_reserve_scheduling/logs/check_waitlists.log</string>
</dict>
</plist>
