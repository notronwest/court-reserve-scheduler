<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.whitemountain.listener</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/notronwest/data/court_reserve_scheduling/scripts/run_listener.sh</string>
    </array>

    <!-- Start immediately and keep restarting if it exits -->
    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/notronwest/Library/Logs/court_reserve/launchd_listener.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/notronwest/Library/Logs/court_reserve/launchd_listener_err.log</string>

    <!-- Throttle restarts — don't spin if it crashes immediately -->
    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
